@model LoginDto
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - ProjectManager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-color: #0c0d21;
            --card-bg: #161631;
            --primary-color: #3b21f0;
            --primary-glow: rgba(59, 33, 240, 0.4);
            --border-color: #23234a;
        }

        body { 
            font-family: 'Outfit', sans-serif; 
            background: var(--bg-color); 
            color: white;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 2.5rem;
            position: relative;
            z-index: 10;
        }

        .premium-card {
            background: rgba(22, 22, 49, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 32px;
            padding: 3rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .brand-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 3rem;
        }

        .brand-logo {
            width: 50px;
            height: 50px;
            background: var(--primary-color);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 25px var(--primary-glow);
            transform: rotate(-3deg);
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #cbd5e1;
            margin-bottom: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-control {
            background: #0f0f2d !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 14px !important;
            padding: 1rem 1.2rem !important;
            color: white !important;
            transition: all 0.3s !important;
        }

        .form-control:focus {
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 15px var(--primary-glow) !important;
        }

        .btn-premium {
            background: var(--primary-color);
            border: none;
            border-radius: 14px;
            padding: 1rem;
            width: 100%;
            color: white;
            font-weight: 700;
            font-size: 1.1rem;
            margin-top: 1.5rem;
            transition: all 0.3s;
            box-shadow: 0 10px 20px var(--primary-glow);
        }

        .btn-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px var(--primary-glow);
            filter: brightness(1.1);
        }

        /* Abstract blurred backgrounds */
        .blob {
            position: absolute;
            width: 400px;
            height: 400px;
            background: var(--primary-color);
            filter: blur(120px);
            opacity: 0.15;
            z-index: 1;
            border-radius: 50%;
        }

        .blob-1 { top: -100px; right: -100px; }
        .blob-2 { bottom: -100px; left: -100px; background: #2a1aa3; }

        .alert-premium {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            border-radius: 14px;
            padding: 1rem;
            margin-bottom: 2rem;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }
    </style>
</head>
<body>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="login-container">
        <div class="brand-header">
            <div class="brand-logo">
                <i data-lucide="package" style="color:white; width:28px; height:28px;"></i>
            </div>
            <h2 class="fw-800 m-0" style="font-size: 1.8rem; letter-spacing: -1px;">ProjectManager</h2>
        </div>

        <div class="premium-card">
            <div class="text-center mb-5">
                <h3 class="fw-bold text-white mb-2">Welcome Back</h3>
                <p style="color: #64748b; font-weight: 500;">Enter your credentials to continue.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert-premium">
                    <i data-lucide="alert-circle" style="width:20px; height:20px;"></i>
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@company.com" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn-premium">
                    Sign In
                </button>
            </form>
        </div>
        
        <div class="text-center mt-5">
            <p style="color: #64748b; font-size: 0.9rem;">&copy; 2026 ProjectManager Platform</p>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
