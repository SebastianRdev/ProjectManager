<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectManager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-color: #0c0d21;
            --sidebar-bg: #0c0d21;
            --card-bg: #161631;
            --primary-color: #3b21f0;
            --primary-glow: rgba(59, 33, 240, 0.4);
            --text-main: #ffffff;
            --text-muted: #ffffff;
            --border-color: #23234a;
            --sidebar-width: 280px;
            --status-draft: #f59e0b;
            --status-published: #10b981;
        }

        body { 
            font-family: 'Outfit', sans-serif; 
            background: var(--bg-color); 
            color: var(--text-main);
            min-height: 100vh; 
            margin: 0;
            overflow-x: hidden;
        }

        .text-muted {
            color: var(--text-muted) !important;
        }

        /* Sidebar Styles */
        .sidebar { 
            width: var(--sidebar-width); 
            background: var(--sidebar-bg); 
            border-right: 1px solid var(--border-color); 
            min-height: 100vh; 
            position: fixed; 
            top: 0; 
            left: 0; 
            z-index: 1000;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 3rem;
            padding: 0 0.5rem;
            text-decoration: none;
        }

        .brand-logo {
            width: 44px;
            height: 44px;
            background: var(--primary-color);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 25px var(--primary-glow);
            transform: rotate(-2deg);
        }

        .brand-name {
            font-size: 1.6rem;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
        }

        .nav-list {
            list-style: none;
            padding: 0;
            margin: 0;
            flex-grow: 1;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 0.9rem 1.2rem;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 14px;
            font-weight: 500;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 6px;
        }

        .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(4px);
        }

        .nav-link.active {
            background: var(--primary-color);
            color: white;
            box-shadow: 0 10px 30px var(--primary-glow);
        }

        .nav-link i {
            width: 20px;
            height: 20px;
        }

        .sidebar-footer {
            margin-top: auto;
            border-top: 1px solid var(--border-color);
            padding-top: 1.5rem;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.5rem;
            margin-bottom: 1.2rem;
        }

        .user-avatar {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #23234a, #1a1a3a);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            border: 1px solid var(--border-color);
        }

        .user-info .name {
            display: block;
            font-size: 0.95rem;
            font-weight: 700;
            color: white;
        }

        .user-info .email {
            display: block;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #ff4d4d;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 0.7rem 1.2rem;
            border-radius: 12px;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            background: rgba(255, 77, 77, 0.1);
            color: #ff4d4d;
        }

        /* Main Content */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            padding: 3rem 5rem;
            min-height: 100vh;
        }

        /* Global UI Elements */
        .premium-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 2.2rem;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
        }

        .btn-premium-primary {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 0.9rem 1.8rem;
            border-radius: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 8px 25px var(--primary-glow);
            text-decoration: none;
        }

        .btn-premium-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 35px var(--primary-glow);
            color: white;
        }

        .search-container {
            position: relative;
            flex-grow: 1;
        }

        .search-input {
            background: #14142b;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 0.8rem 1.2rem 0.8rem 3.2rem;
            color: white;
            width: 100%;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 500;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--primary-color);
            background: #1a1a3a;
            box-shadow: 0 0 0 4px rgba(59, 33, 240, 0.15);
        }

        .search-icon-box {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            width: 20px;
            height: 20px;
        }

        .badge-premium {
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .badge-draft {
            background: rgba(245, 158, 11, 0.12);
            color: #f59e0b;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }
        .badge-draft::before {
            content: '';
            width: 8px;
            height: 8px;
            background: #f59e0b;
            border-radius: 50%;
            box-shadow: 0 0 10px #f59e0b;
        }

        .badge-published {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }
        .badge-published::before {
            content: '';
            width: 8px;
            height: 8px;
            background: #10b981;
            border-radius: 50%;
            box-shadow: 0 0 10px #10b981;
        }

        /* Generic Table Overrides */
        .table-premium {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 14px;
        }

        .table-premium tr {
            background: var(--card-bg);
            transition: all 0.3s ease;
        }

        .table-premium tr:hover {
            background: #1e1e3f;
            transform: scale(1.005);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .table-premium td, .table-premium th {
            padding: 1.4rem 1.8rem;
            border: none;
        }

        .table-premium th {
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1.5px;
            font-weight: 800;
            padding-bottom: 0.8rem;
        }

        .table-premium td:first-child { border-radius: 20px 0 0 20px; }
        .table-premium td:last-child { border-radius: 0 20px 20px 0; }

    </style>
</head>
<body class="d-flex flex-column">
    <!-- Sidebar -->
    <nav class="sidebar flex-column">
        <a href="/" class="brand">
            <div class="brand-logo">
                <i data-lucide="package" class="text-white"></i>
            </div>
            <span class="brand-name">ProjectManager</span>
        </a>

        <ul class="nav-list">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                    <i data-lucide="layout-dashboard"></i>
                    Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")" asp-controller="Projects" asp-action="Index">
                    <i data-lucide="layers"></i>
                    Projects
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProjectTasks" ? "active" : "")" asp-controller="ProjectTasks" asp-action="Index">
                    <i data-lucide="check-square"></i>
                    Tasks
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="user-profile">
                <div class="user-avatar">
                    <i data-lucide="user"></i>
                </div>
                <div class="user-info">
                    <span class="name">Administrator</span>
                    <span class="email">admin@projectmanager.com</span>
                </div>
            </div>
            <a class="logout-btn" asp-controller="Account" asp-action="Logout">
                <i data-lucide="log-out"></i>
                Logout
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-wrapper">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-4 mb-5 shadow-lg" role="alert" style="background: rgba(255, 77, 77, 0.1); color: #ff4d4d;">
                <div class="d-flex align-items-center gap-3">
                    <i data-lucide="alert-circle"></i>
                    @TempData["Error"]
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
